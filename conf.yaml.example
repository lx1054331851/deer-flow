# [!NOTE]
# 仔细阅读 `docs/configuration_guide.md`，并按照自身需求更新配置。
# - 将 `api_key` 替换为你自己的凭据。
# - 如需自定义模型，请替换 `base_url` 和 `model` 名称。
# - 若 LLM 服务器使用自签名证书，请将 `verify_ssl` 设置为 `false`。
# - 每次修改 `conf.yaml` 文件后都需要重启服务。

BASIC_MODEL:
  base_url: https://ark.cn-beijing.volces.com/api/v3
  model: "doubao-1-5-pro-32k-250115"
  api_key: xxxx
  # max_retries: 3 # LLM 调用的最大重试次数
  # verify_ssl: false  # 取消注释以关闭自签名证书的 SSL 验证

# 本地模型配置示例：

# Ollama（已验证，适合本地开发）
# BASIC_MODEL:
#   base_url: "http://localhost:11434/v1"  # Ollama 的 OpenAI 兼容端点
#   model: "qwen3:14b"  # 或 "llama3.2" 等
#   api_key: "ollama"  # Ollama 不需要真实的 API Key
#   max_retries: 3
#   verify_ssl: false  # 本地部署通常不需要进行 SSL 验证

# 将 Google AI Studio 配置为基础平台：
# BASIC_MODEL:
#   platform: "google_aistudio"
#   model: "gemini-2.5-flash"  # 或 "gemini-1.5-pro"、"gemini-2.5-flash-exp" 等
#   api_key: your_gemini_api_key  # 从 https://aistudio.google.com/app/apikey 获取
#   max_retries: 3

# 将 Azure OpenAI 配置为基础平台：
# BASIC_MODEL:
#   model: "azure/gpt-4o-2024-08-06"
#   azure_endpoint: ${AZURE_OPENAI_ENDPOINT}
#   api_version: ${OPENAI_API_VERSION}
#   api_key: ${AZURE_OPENAI_API_KEY}

# 推理模型为可选项。
# 如需用于规划任务，请取消注释以下配置。

# REASONING_MODEL:
#   base_url: https://ark.cn-beijing.volces.com/api/v3
#   model: "doubao-1-5-thinking-pro-m-250428"
#   api_key: xxxx
#   max_retries: 3 # LLM 调用的最大重试次数


# 其他设置：
# 搜索引擎配置（当前仅支持 Tavily）
# SEARCH_ENGINE:
#   engine: tavily
#   # 仅包含以下域名的结果
#   include_domains:
#     - example.com
#     - trusted-news.com
#     - reliable-source.org
#     - gov.cn
#     - edu.cn
#   # 排除以下域名的结果
#   exclude_domains:
#     - example.com
