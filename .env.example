# 应用程序设置
DEBUG=True
APP_ENV=development

# Docker 构建参数
NEXT_PUBLIC_API_URL="http://localhost:8000/api"

AGENT_RECURSION_LIMIT=30

# CORS 设置
# 允许的 CORS 来源列表，使用逗号分隔
# 示例：ALLOWED_ORIGINS=http://localhost:3000,http://example.com
ALLOWED_ORIGINS=http://localhost:3000

# 启用或禁用 MCP 服务器配置，默认值为 false。
# 在受管环境中加固前端和后端之前，请先启用此功能。
# 否则，系统可能会受到攻击。
ENABLE_MCP_SERVER_CONFIGURATION=false

# 启用或禁用 PYTHON_REPL 配置，默认值为 false。
# 在受管环境中加固系统之前，请先启用此功能。
# 否则，系统可能会受到攻击。
ENABLE_PYTHON_REPL=false

# 搜索引擎，支持的取值：tavily（推荐）、duckduckgo、brave_search、arxiv、searx
SEARCH_API=tavily
TAVILY_API_KEY=tvly-xxx
# SEARX_HOST=xxx # 仅当 SEARCH_API 为 searx 时需要（兼容 Searx 与 SearxNG）
# BRAVE_SEARCH_API_KEY=xxx # 仅当 SEARCH_API 为 brave_search 时需要
# JINA_API_KEY=jina_xxx # 可选，默认值为 None

# 可选，RAG 提供方
# RAG_PROVIDER=vikingdb_knowledge_base
# VIKINGDB_KNOWLEDGE_BASE_API_URL="api-knowledgebase.mlp.cn-beijing.volces.com"
# VIKINGDB_KNOWLEDGE_BASE_API_AK="AKxxx"
# VIKINGDB_KNOWLEDGE_BASE_API_SK=""
# VIKINGDB_KNOWLEDGE_BASE_RETRIEVAL_SIZE=15

# RAG_PROVIDER=ragflow
# RAGFLOW_API_URL="http://localhost:9388"
# RAGFLOW_API_KEY="ragflow-xxx"
# RAGFLOW_RETRIEVAL_SIZE=10
# RAGFLOW_CROSS_LANGUAGES=English,Chinese,Spanish,French,German,Japanese,Korean # 可选。若需使用 RAGFlow 的跨语言检索，请使用英文逗号分隔每个语言

# RAG_PROVIDER=dify
# DIFY_API_URL="https://api.dify.ai/v1"
# DIFY_API_KEY="dataset-xxx"

# MOI 是一款主要面向企业用户的混合型数据库（https://www.matrixorigin.io/matrixone-intelligence）
# RAG_PROVIDER=moi
# MOI_API_URL="https://cluster.matrixonecloud.cn"
# MOI_API_KEY="xxx-xxx-xxx-xxx"
# MOI_RETRIEVAL_SIZE=10
# MOI_LIST_LIMIT=10


# RAG_PROVIDER：milvus（在 Zilliz Cloud 免费 Milvus 实例上运行：https://docs.zilliz.com/docs/quick-start）
# RAG_PROVIDER=milvus
# MILVUS_URI=<自建 Milvus 或 Zilliz Cloud 的端点>
# MILVUS_USER=<自建 Milvus 或 Zilliz Cloud 的用户名>
# MILVUS_PASSWORD=<自建 Milvus 或 Zilliz Cloud 的密码>
# MILVUS_COLLECTION=documents
# MILVUS_EMBEDDING_PROVIDER=openai # 支持 openai、dashscope
# MILVUS_EMBEDDING_BASE_URL=
# MILVUS_EMBEDDING_MODEL=
# MILVUS_EMBEDDING_API_KEY=
# MILVUS_AUTO_LOAD_EXAMPLES=true

# RAG_PROVIDER：milvus（在 Mac 或 Linux 上使用 Milvus Lite）
# RAG_PROVIDER=milvus
# MILVUS_URI=./milvus_demo.db
# MILVUS_COLLECTION=documents
# MILVUS_EMBEDDING_PROVIDER=openai # 支持 openai、dashscope
# MILVUS_EMBEDDING_BASE_URL=
# MILVUS_EMBEDDING_MODEL=
# MILVUS_EMBEDDING_API_KEY=
# MILVUS_AUTO_LOAD_EXAMPLES=true

# 可选，使用火山引擎 TTS 生成播客
VOLCENGINE_TTS_APPID=xxx
VOLCENGINE_TTS_ACCESS_TOKEN=xxx
# VOLCENGINE_TTS_CLUSTER=volcano_tts # 可选，默认值为 volcano_tts
# VOLCENGINE_TTS_VOICE_TYPE=BV700_V2_streaming # 可选，默认值为 BV700_V2_streaming

# 可选，用于 LangSmith 的链路追踪与监控
# LANGSMITH_TRACING=true
# LANGSMITH_ENDPOINT="https://api.smith.langchain.com"
# LANGSMITH_API_KEY="xxx"
# LANGSMITH_PROJECT="xxx"

# [!NOTE]
# 关于模型设置和其它配置，请参阅 `docs/configuration_guide.md`

# 可选，用于 LangGraph 的 MongoDB 检查点存储
# 启用 LangGraph 检查点保存器，支持 MongoDB、Postgres
#LANGGRAPH_CHECKPOINT_SAVER=true
# 设置用于保存检查点的数据库 URL
#LANGGRAPH_CHECKPOINT_DB_URL=mongodb://localhost:27017/
#LANGGRAPH_CHECKPOINT_DB_URL=postgresql://localhost:5432/postgres
